RewriteEngine On

# ❌ NO tocar archivos reales (JS, CSS, PHP, carpetas)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ✔ solo agregar .php si existe
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

<Files ".env">
    Require all denied
</Files>